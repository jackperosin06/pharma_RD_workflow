+def test_run_delivery_gpt_renderer_mocked_openai(
+    tmp_path: Path, monkeypatch: pytest.MonkeyPatch
+) -> None:
+    monkeypatch.setenv("PHARMA_RD_REPORT_RENDERER", "gpt")
