# Copy to `.env` for local overrides. Never commit real secrets (NFR-S1).
PHARMA_RD_ENV=development
# Epic 8 / FR26: practice (default), staging, or production — demo uses practice; no enterprise SSO for MVP (FR34 roadmap)
PHARMA_RD_DEPLOYMENT_PROFILE=practice
# Epic 8 / FR32 (NFR-S2): optional shared secret — when set, run/runs/status/retry-stage need PHARMA_RD_CLI_ACCESS_TOKEN to match (never commit real values; NFR-S1)
# PHARMA_RD_ARTIFACT_ACCESS_TOKEN=
# PHARMA_RD_CLI_ACCESS_TOKEN=   # export in shell for CLI; not loaded from .env by Settings
# SQLite path (default: data/app.db under cwd when using `uv run` from pharma_rd/)
PHARMA_RD_DB_PATH=data/app.db
# Run history retention in days (default 30 per NFR-R2 practice baseline)
PHARMA_RD_RETENTION_DAYS=30
# JSON artifacts per run/stage (default: artifacts/ under cwd)
PHARMA_RD_ARTIFACTS_ROOT=artifacts
# Structured JSON log level for pharma_rd loggers (default INFO)
PHARMA_RD_LOG_LEVEL=INFO
# Cron for pharma-rd scheduler (five fields; default weekly Sunday 00:00 in timezone below)
PHARMA_RD_SCHEDULE_CRON="0 0 * * sun"
# IANA timezone for cron interpretation (default UTC)
PHARMA_RD_SCHEDULER_TIMEZONE=UTC
# Outbound HTTP: timeouts and bounded retries for connector calls (story 2.2)
# Epic 8 / FR25: PHARMA_RD_CONNECTOR_PROBE_URL must be http(s) with a host when set
# PHARMA_RD_HTTP_TIMEOUT_SECONDS=30
# PHARMA_RD_HTTP_MAX_RETRIES=3
# PHARMA_RD_HTTP_RETRY_BACKOFF_SECONDS=0.5
# Optional: GET this URL at each stage via shared client (unset = no probe)
# PHARMA_RD_CONNECTOR_PROBE_URL=

# Clinical agent (Epic 3 / FR6): comma-separated TA labels for PubMed Title/Abstract search
# Epic 8 / FR23: validated at load (max 32 labels, max 128 chars each; letters/digits/spaces/_/-; no empty between commas); empty = no TA scope
# PHARMA_RD_THERAPEUTIC_AREAS=oncology,diabetes
# PHARMA_RD_PUBMED_MAX_RESULTS=5
# PHARMA_RD_PUBMED_TOOL_EMAIL=ops@example.com
# Epic 8 / FR25: PHARMA_RD_PUBMED_EUTILS_BASE must be http(s) with a host
# PHARMA_RD_PUBMED_EUTILS_BASE=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# Demo / practice: load publication rows from JSON instead of live PubMed (same idea as PHARMA_RD_COMPETITOR_REGULATORY_PATH). Top-level "publications" array or a JSON array of {title, summary, reference, source?}.
# PHARMA_RD_CLINICAL_FIXTURE_PATH=tests/fixtures/clinical/sample.json
# PHARMA_RD_CLINICAL_FIXTURE_MAX_FILE_BYTES=262144

# Internal research JSON (Epic 3 / FR7): one file or a directory of *.json
# PHARMA_RD_INTERNAL_RESEARCH_PATH=tests/fixtures/internal_research/sample.json
# PHARMA_RD_INTERNAL_RESEARCH_MAX_FILE_BYTES=262144

# GPT clinical analysis (Epic 3 / story 3.3): optional OpenAI Chat Completions after PubMed + internal research merge
# Set PHARMA_RD_OPENAI_API_KEY in .env (pharma_rd/) or export in the shell — never commit real keys (NFR-S1)
# Unset or empty = skip GPT step; integration_notes record the skip; stage still completes (NFR-I1)
# PHARMA_RD_OPENAI_API_KEY=
# PHARMA_RD_OPENAI_MODEL=gpt-4o
# PHARMA_RD_OPENAI_TIMEOUT_SECONDS=120
# PHARMA_RD_INSIGHT_ORG_DISPLAY_NAME=iNova
# GPT competitor analysis (Epic 4 / story 4.4): same variables as above; runs after regulatory rows are loaded
# GPT consumer insight analysis (Epic 5 / story 5.4): same PHARMA_RD_OPENAI_* as 3.3/4.4; runs after FR11–FR13 signals are aggregated
# GPT synthesis (Epic 6 / story 6.5): gpt = OpenAI JSON synthesis when PHARMA_RD_OPENAI_API_KEY is set; deterministic = legacy ranking without LLM (offline/CI)
# PHARMA_RD_SYNTHESIS_MODE=gpt
# PHARMA_RD_OPENAI_SYNTHESIS_TIMEOUT_SECONDS=180
# GPT report delivery (Epic 7 / story 7.6): template = string renderer (default); gpt = OpenAI narrative HTML+Markdown
# PHARMA_RD_REPORT_RENDERER=template
# PHARMA_RD_OPENAI_REPORT_DELIVERY_TIMEOUT_SECONDS=150
# PHARMA_RD_REPORT_GPT_FALLBACK_ON_ERROR=true

# Competitor agent (Epic 4 / FR8): comma-separated competitor labels; observation window (calendar days)
# Epic 8 / FR24: validated at load (max 32 labels, max 128 chars each; same as TA plus & . ( ); no empty between commas); empty = gaps path
# PHARMA_RD_COMPETITOR_WATCHLIST=AcmePharma,BetaBio
# PHARMA_RD_COMPETITOR_OBSERVATION_DAYS=30
# Pipeline disclosure watch scopes (Epic 4 / FR9): comma-separated labels; match fixture scope_tags
# PHARMA_RD_PIPELINE_DISCLOSURE_SCOPES=Oncology,Rare disease
# Optional: JSON fixture path (approvals, disclosures, pipeline_disclosures, patent_filing_flags); unset = OpenFDA when watchlist set
# PHARMA_RD_COMPETITOR_REGULATORY_PATH=tests/fixtures/competitor_regulatory/sample.json
# PHARMA_RD_COMPETITOR_REGULATORY_MAX_FILE_BYTES=262144
# Epic 8 / FR25: PHARMA_RD_OPENFDA_DRUGSFDA_URL must be http(s) with a host
# PHARMA_RD_OPENFDA_DRUGSFDA_URL=https://api.fda.gov/drug/drugsfda.json
# PHARMA_RD_OPENFDA_MAX_RESULTS=5

# Consumer agent (Epic 5 / FR11): optional JSON fixture; practice mock when unset
# PHARMA_RD_CONSUMER_FEEDBACK_PATH=tests/fixtures/consumer_feedback/demo.json
# PHARMA_RD_CONSUMER_FEEDBACK_MAX_FILE_BYTES=262144
# PHARMA_RD_PRACTICE_CONSUMER_MOCK=true

# Pharmacy sales trends (Epic 5 / FR12): optional JSON fixture
# PHARMA_RD_PHARMACY_SALES_PATH=tests/fixtures/pharmacy_sales/sample.json
# PHARMA_RD_PHARMACY_SALES_MAX_FILE_BYTES=262144

# Unmet need / demand signals (Epic 5 / FR13): optional JSON fixture
# PHARMA_RD_UNMET_NEED_DEMAND_PATH=tests/fixtures/unmet_need_demand/sample.json
# PHARMA_RD_UNMET_NEED_DEMAND_MAX_FILE_BYTES=262144

# Report distribution (Epic 7 / FR19): none | file_drop | smtp (smtp not implemented in MVP)
# PHARMA_RD_DISTRIBUTION_CHANNEL=none
# PHARMA_RD_DISTRIBUTION_DROP_DIR=/var/pharma_rd/drops
# PHARMA_RD_RD_RECIPIENT_EMAIL=rd@example.com
# PHARMA_RD_MARKETING_RECIPIENT_EMAIL=marketing@example.com

# Slack incoming webhook (Epic 7 / FR19): optional Block Kit ping after report.html exists
# Epic 8 / FR25: PHARMA_RD_SLACK_WEBHOOK_URL must be https:// when set (NFR-S1)
# PHARMA_RD_SLACK_WEBHOOK_URL=
# PHARMA_RD_SLACK_WEBHOOK_TIMEOUT_SECONDS=10
# PDF to Slack requires a bot token + channel (incoming webhooks cannot attach files). Invite the app to the channel.
# PHARMA_RD_SLACK_BOT_TOKEN=xoxb-...
# PHARMA_RD_SLACK_PDF_CHANNEL_ID=C01234567890
# PHARMA_RD_SLACK_PDF_UPLOAD_TIMEOUT_SECONDS=60
# Render report.pdf from HTML (WeasyPrint); set false in CI if PDF deps are unavailable
# PHARMA_RD_REPORT_PDF_ENABLED=true
# Write report.docx (python-docx) for Word-friendly sharing
# PHARMA_RD_REPORT_DOCX_ENABLED=true
