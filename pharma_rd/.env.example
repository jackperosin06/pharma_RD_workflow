# Copy to `.env` for local overrides. Never commit real secrets (NFR-S1).
PHARMA_RD_ENV=development
# SQLite path (default: data/app.db under cwd when using `uv run` from pharma_rd/)
PHARMA_RD_DB_PATH=data/app.db
# Run history retention in days (default 30 per NFR-R2 practice baseline)
PHARMA_RD_RETENTION_DAYS=30
# JSON artifacts per run/stage (default: artifacts/ under cwd)
PHARMA_RD_ARTIFACTS_ROOT=artifacts
